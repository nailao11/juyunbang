/* 关于我们样式 */

.about-logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.4);
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 72rpx;
  font-weight: 800;
  color: #fff;
}

.app-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 卡片 */
.about-card {
  padding: 28rpx;
}

.about-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.about-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 20rpx;
}

/* 功能列表 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.feature-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* 链接 */
.about-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.link-text {
  font-size: 28rpx;
  color: var(--text);
}

.link-value {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.link-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

.about-divider {
  height: 1rpx;
  background: var(--border);
}

/* 免责 */
.disclaimer-text {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.8;
}

/* 版权 */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.copyright-text {
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.8;
}
