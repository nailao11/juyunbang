<!--pages/discover/discover.wxml - 发现页-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">

  <!-- 顶部渐变 -->
  <view class="discover-header">
    <text class="discover-title">发现</text>
    <text class="discover-subtitle">探索更多精彩剧集</text>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry card" style="margin: -30rpx 24rpx 20rpx;">
    <view class="entry-grid">
      <view class="entry-item" bindtap="navigateTo" data-url="/pages/tracking-list/tracking-list">
        <view class="entry-icon-wrap" style="background: linear-gradient(135deg, #667eea, #764ba2);">
          <image class="entry-icon" src="/images/icons/list.png" mode="aspectFit"></image>
        </view>
        <text class="entry-text">追剧清单</text>
      </view>
      <view class="entry-item" bindtap="navigateTo" data-url="/pages/compare/compare">
        <view class="entry-icon-wrap" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
          <image class="entry-icon" src="/images/icons/compare.png" mode="aspectFit"></image>
        </view>
        <text class="entry-text">对比工具</text>
      </view>
      <view class="entry-item" bindtap="navigateTo" data-url="/pages/news-list/news-list">
        <view class="entry-icon-wrap" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
          <image class="entry-icon" src="/images/icons/news.png" mode="aspectFit"></image>
        </view>
        <text class="entry-text">资讯快讯</text>
      </view>
      <view class="entry-item" bindtap="navigateTo" data-url="/pages/tracking-report/tracking-report">
        <view class="entry-icon-wrap" style="background: linear-gradient(135deg, #2dce89, #26d0ce);">
          <image class="entry-icon" src="/images/icons/report.png" mode="aspectFit"></image>
        </view>
        <text class="entry-text">追剧报告</text>
      </view>
    </view>
  </view>

  <!-- 类型标签浏览 -->
  <view class="section-header container">
    <text class="section-title">分类浏览</text>
  </view>
  <scroll-view scroll-x class="genre-scroll">
    <view class="genre-tags">
      <view class="genre-tag {{currentGenre === item.key ? 'active' : ''}}"
            wx:for="{{genres}}" wx:key="key"
            bindtap="switchGenre" data-genre="{{item.key}}">
        <text class="genre-emoji">{{item.emoji}}</text>
        <text class="genre-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 高分推荐 -->
  <view class="section-header container">
    <text class="section-title">高分推荐</text>
    <view class="section-more" bindtap="goRankDetail" data-type="highscore">
      <text class="more-text">更多</text>
      <text class="more-arrow">›</text>
    </view>
  </view>
  <scroll-view scroll-x class="horizontal-scroll">
    <view class="h-scroll-inner">
      <view class="recommend-card" wx:for="{{highScoreList}}" wx:key="id"
            bindtap="goDetail" data-id="{{item.id}}">
        <image class="recommend-poster" src="{{item.poster_url || '/images/default/poster.png'}}"
               mode="aspectFill" lazy-load></image>
        <view class="recommend-score" wx:if="{{item.douban_score}}">
          <text class="score-num">{{item.douban_score}}</text>
        </view>
        <view class="recommend-info">
          <text class="recommend-title">{{item.title}}</text>
          <text class="recommend-genre">{{item.genre || ''}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 冷门佳作 -->
  <view class="section-header container">
    <text class="section-title">冷门佳作</text>
    <view class="section-more" bindtap="goRankDetail" data-type="hidden-gem">
      <text class="more-text">更多</text>
      <text class="more-arrow">›</text>
    </view>
  </view>
  <scroll-view scroll-x class="horizontal-scroll">
    <view class="h-scroll-inner">
      <view class="recommend-card" wx:for="{{hiddenGemList}}" wx:key="id"
            bindtap="goDetail" data-id="{{item.id}}">
        <image class="recommend-poster" src="{{item.poster_url || '/images/default/poster.png'}}"
               mode="aspectFill" lazy-load></image>
        <view class="recommend-score" wx:if="{{item.douban_score}}">
          <text class="score-num">{{item.douban_score}}</text>
        </view>
        <view class="recommend-info">
          <text class="recommend-title">{{item.title}}</text>
          <text class="recommend-genre">{{item.genre || ''}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 待播期待榜 -->
  <view class="section-header container">
    <text class="section-title">待播期待榜</text>
    <view class="section-more" bindtap="goRankDetail" data-type="upcoming">
      <text class="more-text">查看全部</text>
      <text class="more-arrow">›</text>
    </view>
  </view>
  <view class="upcoming-list container">
    <view class="upcoming-item card" wx:for="{{upcomingList}}" wx:key="id"
          bindtap="goDetail" data-id="{{item.id}}">
      <view class="upcoming-rank">
        <text class="upcoming-rank-num {{index < 3 ? 'rank-' + (index+1) : 'rank-other'}}">{{index + 1}}</text>
      </view>
      <image class="upcoming-poster" src="{{item.poster_url || '/images/default/poster.png'}}"
             mode="aspectFill" lazy-load></image>
      <view class="upcoming-info flex-1">
        <text class="upcoming-title">{{item.title}}</text>
        <view class="upcoming-meta">
          <text class="upcoming-cast">{{item.cast || ''}}</text>
        </view>
        <view class="upcoming-bottom">
          <text class="upcoming-date" wx:if="{{item.air_date}}">预计 {{item.air_date}}</text>
          <text class="upcoming-expect">{{item.expect_count || 0}}人期待</text>
        </view>
      </view>
      <view class="upcoming-action" bindtap="toggleExpect" data-id="{{item.id}}" catchtap="toggleExpect">
        <view class="expect-btn {{item.is_expected ? 'expected' : ''}}">
          <text class="expect-text">{{item.is_expected ? '已期待' : '期待'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-dots" wx:if="{{loading}}">
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
  </view>

  <!-- 底部安全距离 -->
  <view style="height: 120rpx;"></view>
</view>
