/* 发现页样式 */

/* 顶部 */
.discover-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 70rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.discover-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.discover-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 8rpx;
}

/* 快捷入口 */
.quick-entry {
  position: relative;
  z-index: 2;
}

.entry-grid {
  display: flex;
  justify-content: space-around;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.25);
}

.entry-icon {
  width: 48rpx;
  height: 48rpx;
}

.entry-text {
  font-size: 24rpx;
  color: var(--text);
  font-weight: 500;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  padding-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.section-more {
  display: flex;
  align-items: center;
}

.more-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.more-arrow {
  font-size: 28rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

/* 分类标签 */
.genre-scroll {
  white-space: nowrap;
  padding: 0 0 12rpx;
}

.genre-tags {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.genre-tag {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--card);
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.genre-tag.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.genre-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.genre-name {
  font-size: 26rpx;
  color: var(--text);
  white-space: nowrap;
}

.genre-tag.active .genre-name {
  color: #fff;
  font-weight: 600;
}

/* 横向滚动推荐 */
.horizontal-scroll {
  white-space: nowrap;
  padding: 0 0 12rpx;
}

.h-scroll-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 20rpx;
}

.recommend-card {
  display: inline-block;
  width: 240rpx;
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--card);
  box-shadow: var(--shadow);
  position: relative;
}

.recommend-poster {
  width: 240rpx;
  height: 340rpx;
  display: block;
  background: var(--border);
}

.recommend-score {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(8px);
  border-radius: 10rpx;
  padding: 4rpx 12rpx;
}

.score-num {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFD700;
}

.recommend-info {
  padding: 16rpx;
  white-space: normal;
}

.recommend-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-genre {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* 待播期待榜 */
.upcoming-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.upcoming-rank {
  width: 48rpx;
  flex-shrink: 0;
  text-align: center;
}

.upcoming-rank-num {
  font-size: 32rpx;
  font-weight: 800;
}

.upcoming-poster {
  width: 72rpx;
  height: 100rpx;
  border-radius: 10rpx;
  margin: 0 16rpx;
  flex-shrink: 0;
  background: var(--border);
}

.upcoming-info {
  overflow: hidden;
  min-width: 0;
}

.upcoming-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upcoming-meta {
  margin-top: 6rpx;
}

.upcoming-cast {
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.upcoming-bottom {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 16rpx;
}

.upcoming-date {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

.upcoming-expect {
  font-size: 22rpx;
  color: var(--text-light);
}

.upcoming-action {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.expect-btn {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--primary);
  background: transparent;
}

.expect-btn .expect-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.expect-btn.expected {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: transparent;
}

.expect-btn.expected .expect-text {
  color: #fff;
}
