/* 资讯详情样式 */

.article-header {
  padding: 16rpx 0 24rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text);
  line-height: 1.4;
  display: block;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.article-source {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.article-dot {
  font-size: 24rpx;
  color: var(--text-light);
}

.article-time {
  font-size: 24rpx;
  color: var(--text-light);
}

.article-cover {
  width: 100%;
  border-radius: var(--radius);
  margin-bottom: 24rpx;
}

/* 文章内容 */
.article-body {
  padding: 8rpx 0;
}

.article-text {
  font-size: 30rpx;
  color: var(--text);
  line-height: 2;
  display: block;
}

/* 标签 */
.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid var(--border);
  margin-top: 32rpx;
}

.article-tag {
  font-size: 24rpx;
  color: var(--primary);
  padding: 8rpx 20rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 24rpx;
}

/* 相关剧集 */
.related-dramas {
  padding: 24rpx 0;
  border-top: 1rpx solid var(--border);
}

.related-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 16rpx;
}

.related-drama-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.related-drama-item:last-child {
  border-bottom: none;
}

.rd-poster {
  width: 64rpx;
  height: 88rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--border);
}

.rd-info {
  overflow: hidden;
}

.rd-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.rd-heat {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.rd-arrow {
  font-size: 32rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

/* 分享按钮 */
.article-actions {
  padding: 32rpx 0;
  text-align: center;
}

.share-btn {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: normal;
}

.share-btn::after {
  border: none;
}

.share-btn-text {
  color: #fff;
}
