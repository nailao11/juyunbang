<!--pages/news-detail/news-detail.wxml - 资讯详情-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">
  <view class="container" wx:if="{{article.title}}">

    <!-- 文章头部 -->
    <view class="article-header">
      <text class="article-title">{{article.title}}</text>
      <view class="article-meta">
        <text class="article-source">{{article.source || '剧云榜'}}</text>
        <text class="article-dot">·</text>
        <text class="article-time">{{article.time_display}}</text>
      </view>
    </view>

    <!-- 封面图 -->
    <image class="article-cover" wx:if="{{article.cover_url}}"
           src="{{article.cover_url}}" mode="widthFix"></image>

    <!-- 文章内容 -->
    <view class="article-body">
      <rich-text nodes="{{article.content_html}}" wx:if="{{article.content_html}}"></rich-text>
      <text class="article-text" wx:else>{{article.content}}</text>
    </view>

    <!-- 标签 -->
    <view class="article-tags" wx:if="{{article.tags && article.tags.length > 0}}">
      <text class="article-tag" wx:for="{{article.tags}}" wx:key="*this">
        #{{item}}
      </text>
    </view>

    <!-- 相关剧集 -->
    <view class="related-dramas" wx:if="{{article.related_dramas && article.related_dramas.length > 0}}">
      <text class="related-label">相关剧集</text>
      <view class="related-drama-item" wx:for="{{article.related_dramas}}" wx:key="id"
            bindtap="goDetail" data-id="{{item.id}}">
        <image class="rd-poster" src="{{item.poster_url || '/images/default/poster.png'}}"
               mode="aspectFill"></image>
        <view class="rd-info flex-1">
          <text class="rd-title">{{item.title}}</text>
          <text class="rd-heat" wx:if="{{item.heat_display}}">热度 {{item.heat_display}}</text>
        </view>
        <text class="rd-arrow">›</text>
      </view>
    </view>

    <!-- 分享栏 -->
    <view class="article-actions">
      <button class="share-btn" open-type="share">
        <text class="share-btn-text">分享给朋友</text>
      </button>
    </view>

  </view>

  <!-- 加载中 -->
  <view class="loading-dots" wx:if="{{loading}}">
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
  </view>
</view>
