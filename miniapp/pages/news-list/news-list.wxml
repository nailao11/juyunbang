<!--pages/news-list/news-list.wxml - 资讯列表-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">

  <!-- 分类Tab -->
  <scroll-view scroll-x class="news-category-scroll">
    <view class="capsule-tabs" style="padding: 12rpx 24rpx;">
      <view class="capsule-tab {{currentCategory === item.key ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="key"
            bindtap="switchCategory" data-category="{{item.key}}">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 资讯列表 -->
  <view class="news-list container" wx:if="{{newsList.length > 0}}">
    <!-- 头条新闻 (第一条大图) -->
    <view class="news-featured card" wx:if="{{!currentCategory && newsList[0]}}"
          bindtap="goDetail" data-id="{{newsList[0].id}}">
      <image class="featured-img" src="{{newsList[0].cover_url || '/images/default/news.png'}}"
             mode="aspectFill"></image>
      <view class="featured-overlay">
        <text class="featured-category">{{newsList[0].category_name || '快讯'}}</text>
        <text class="featured-title">{{newsList[0].title}}</text>
        <text class="featured-time">{{newsList[0].time_display}}</text>
      </view>
    </view>

    <!-- 普通新闻列表 -->
    <view class="news-item card" wx:for="{{newsList}}" wx:key="id"
          wx:if="{{currentCategory || index > 0}}"
          bindtap="goDetail" data-id="{{item.id}}">
      <view class="news-content flex-1">
        <text class="news-title">{{item.title}}</text>
        <view class="news-bottom">
          <text class="news-source">{{item.source || '剧云榜'}}</text>
          <text class="news-dot">·</text>
          <text class="news-time">{{item.time_display}}</text>
          <text class="news-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
        </view>
      </view>
      <image class="news-thumb" wx:if="{{item.cover_url}}"
             src="{{item.cover_url}}" mode="aspectFill" lazy-load></image>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-dots" wx:if="{{loading}}">
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && newsList.length === 0}}">
    <image src="/images/default/empty.png" class="icon" mode="aspectFit"></image>
    <text class="text">暂无资讯</text>
  </view>
</view>
