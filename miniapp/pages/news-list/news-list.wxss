/* 资讯列表样式 */

.news-category-scroll {
  white-space: nowrap;
  background: var(--card);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

/* 头条 */
.news-featured {
  padding: 0;
  overflow: hidden;
  position: relative;
  border-radius: var(--radius);
}

.featured-img {
  width: 100%;
  height: 360rpx;
  display: block;
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 24rpx 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
}

.featured-category {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  background: rgba(102, 126, 234, 0.8);
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  display: inline-block;
}

.featured-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.featured-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 8rpx;
}

/* 新闻项 */
.news-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  gap: 16rpx;
}

.news-content {
  overflow: hidden;
  min-width: 0;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
}

.news-bottom {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.news-source {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.news-dot {
  font-size: 22rpx;
  color: var(--text-light);
}

.news-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.news-tag {
  font-size: 20rpx;
  color: var(--primary);
  padding: 2rpx 10rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 6rpx;
}

.news-thumb {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: var(--border);
}
