<!--pages/index/index.wxml - 首页：实时热度排行-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">

  <!-- 顶部渐变头部 -->
  <view class="header">
    <view class="header-content">
      <text class="header-title">剧云榜</text>
      <text class="header-subtitle">全平台实时热度监控</text>
    </view>

    <!-- 搜索栏 -->
    <view class="search-bar" bindtap="goSearch">
      <text class="search-icon-text">🔍</text>
      <text class="search-placeholder">搜索剧集、演员、导演</text>
    </view>
  </view>

  <!-- 更新提示 -->
  <view class="update-tip" wx:if="{{updateTime}}">
    <text class="update-dot"></text>
    <text>实时数据 · 更新于 {{updateTime}}</text>
    <view class="refresh-btn" bindtap="refreshData">
      <text class="refresh-icon-text">↻</text>
    </view>
  </view>

  <!-- 平台切换 -->
  <scroll-view scroll-x class="platform-scroll">
    <view class="capsule-tabs">
      <view class="capsule-tab {{currentPlatform === '' ? 'active' : ''}}"
            bindtap="switchPlatform" data-platform="">全平台</view>
      <view class="capsule-tab {{currentPlatform === item.short_name ? 'active' : ''}}"
            wx:for="{{platforms}}" wx:key="short_name"
            bindtap="switchPlatform" data-platform="{{item.short_name}}">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 类型筛选 -->
  <view class="type-tabs">
    <view class="type-tab {{currentType === '' ? 'active' : ''}}"
          bindtap="switchType" data-type="">全部</view>
    <view class="type-tab {{currentType === 'tv_drama' ? 'active' : ''}}"
          bindtap="switchType" data-type="tv_drama">电视剧</view>
    <view class="type-tab {{currentType === 'web_drama' ? 'active' : ''}}"
          bindtap="switchType" data-type="web_drama">网剧</view>
    <view class="type-tab {{currentType === 'variety' ? 'active' : ''}}"
          bindtap="switchType" data-type="variety">综艺</view>
    <view class="type-tab {{currentType === 'anime' ? 'active' : ''}}"
          bindtap="switchType" data-type="anime">动漫</view>
  </view>

  <!-- 热度排行列表 -->
  <view class="rank-list" wx:if="{{rankList.length > 0}}">
    <view class="rank-item card" wx:for="{{rankList}}" wx:key="id"
          bindtap="goDetail" data-id="{{item.id}}">

      <!-- 排名 -->
      <view class="rank-num-wrap">
        <text class="rank-num {{index < 3 ? 'rank-' + (index + 1) : 'rank-other'}}">
          {{index + 1}}
        </text>
      </view>

      <!-- 海报缩略图 -->
      <image class="rank-poster" src="{{item.poster_url || '/images/default/poster.png'}}"
             mode="aspectFill" lazy-load></image>

      <!-- 剧集信息 -->
      <view class="rank-info flex-1">
        <text class="rank-title">{{item.title}}</text>
        <view class="rank-meta">
          <view class="platform-tag" style="background:{{item.platform_color || '#667eea'}}">
            {{item.platform_name || '全平台'}}
          </view>
          <text class="status-{{item.status}}">{{item.status === 'airing' ? '热播中' : (item.status === 'finished' ? '已完结' : '待播')}}</text>
          <text class="rank-episode" wx:if="{{item.current_episode}}">更新至{{item.current_episode}}集</text>
        </view>
        <!-- 热度条 -->
        <view class="heat-bar">
          <view class="heat-bar-fill" style="width: {{item.heat_value / maxHeat * 100}}%"></view>
        </view>
      </view>

      <!-- 热度值和涨跌 -->
      <view class="rank-heat-wrap">
        <text class="heat-value">{{item.heat_display}}</text>
        <view class="trend-wrap" wx:if="{{item.trend !== 'new'}}">
          <text class="trend-{{item.trend}}">
            {{item.trend === 'up' ? '▲' : (item.trend === 'down' ? '▼' : '━')}}
            {{item.heat_change_pct ? item.heat_change_pct + '%' : ''}}
          </text>
        </view>
        <view wx:else class="trend-new">NEW</view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-dots" wx:if="{{loading}}">
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && rankList.length === 0}}">
    <image src="/images/default/empty.png" class="icon" mode="aspectFit"></image>
    <text class="text">暂无热度数据</text>
    <text class="text" style="font-size:24rpx;margin-top:12rpx;">请稍后刷新试试</text>
  </view>

  <!-- 底部安全距离 -->
  <view style="height: 120rpx;"></view>
</view>
