/* 榜单详情样式 */

/* 头部 */
.rd-header {
  position: relative;
  padding: 40rpx 32rpx 60rpx;
  overflow: hidden;
}

.rd-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.rd-header-content {
  position: relative;
  z-index: 2;
}

.rd-header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.rd-header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 8rpx;
}

.rd-update {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-top: 12rpx;
}

/* 前三名 */
.rd-top3 {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 16rpx 32rpx;
  margin-top: -20rpx;
  gap: 16rpx;
}

.rd-top-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--card);
  border-radius: var(--radius);
  padding: 20rpx 16rpx;
  box-shadow: var(--shadow);
  position: relative;
  width: 200rpx;
}

.rd-top-item.rank-1st {
  width: 220rpx;
  padding-bottom: 28rpx;
  transform: translateY(-20rpx);
}

.top-crown {
  position: absolute;
  top: -28rpx;
  font-size: 36rpx;
}

.top-rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
}

.top-rank-badge.rank-1 {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.5);
}

.top-rank-badge.rank-2 {
  background: linear-gradient(135deg, #E8E8E8, #A0A0A0);
  box-shadow: 0 4rpx 12rpx rgba(160, 160, 160, 0.4);
}

.top-rank-badge.rank-3 {
  background: linear-gradient(135deg, #CD7F32, #8B5E3C);
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.4);
}

.top-poster {
  width: 120rpx;
  height: 168rpx;
  border-radius: 12rpx;
  background: var(--border);
  margin-bottom: 8rpx;
}

.rank-1st .top-poster {
  width: 140rpx;
  height: 196rpx;
}

.top-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

.top-value {
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  -webkit-background-clip: text;
  color: transparent;
  margin-top: 4rpx;
}

/* 列表项 */
.rd-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.rd-rank-num {
  font-size: 32rpx;
  font-weight: 700;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.rd-poster {
  width: 72rpx;
  height: 100rpx;
  border-radius: 10rpx;
  margin: 0 16rpx;
  flex-shrink: 0;
  background: var(--border);
}

.rd-info {
  overflow: hidden;
  min-width: 0;
}

.rd-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rd-meta {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
  gap: 8rpx;
}

.rd-genre {
  font-size: 22rpx;
  color: var(--text-light);
}

.rd-value-wrap {
  flex-shrink: 0;
  margin-left: 12rpx;
}
