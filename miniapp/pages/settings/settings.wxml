<!--pages/settings/settings.wxml - 设置页-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">
  <view class="container">

    <!-- 通知设置 -->
    <view class="card settings-card">
      <view class="settings-group-title">通知设置</view>
      <view class="settings-item">
        <text class="settings-label">追剧更新提醒</text>
        <switch checked="{{notifyUpdate}}" bindchange="toggleNotifyUpdate" color="#667eea" />
      </view>
      <view class="settings-divider"></view>
      <view class="settings-item">
        <text class="settings-label">热度变化提醒</text>
        <switch checked="{{notifyHeat}}" bindchange="toggleNotifyHeat" color="#667eea" />
      </view>
      <view class="settings-divider"></view>
      <view class="settings-item">
        <text class="settings-label">榜单上新提醒</text>
        <switch checked="{{notifyRank}}" bindchange="toggleNotifyRank" color="#667eea" />
      </view>
    </view>

    <!-- 显示设置 -->
    <view class="card settings-card">
      <view class="settings-group-title">显示设置</view>
      <view class="settings-item">
        <text class="settings-label">深色模式</text>
        <view class="theme-options">
          <view class="theme-opt {{themeMode === 'light' ? 'active' : ''}}"
                bindtap="setTheme" data-theme="light">浅色</view>
          <view class="theme-opt {{themeMode === 'dark' ? 'active' : ''}}"
                bindtap="setTheme" data-theme="dark">深色</view>
          <view class="theme-opt {{themeMode === 'auto' ? 'active' : ''}}"
                bindtap="setTheme" data-theme="auto">跟随系统</view>
        </view>
      </view>
      <view class="settings-divider"></view>
      <view class="settings-item">
        <text class="settings-label">默认榜单类型</text>
        <picker bindchange="onDefaultRankChange" value="{{defaultRankIndex}}"
                range="{{rankOptions}}">
          <view class="settings-picker">
            <text class="picker-value">{{rankOptions[defaultRankIndex]}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 缓存 -->
    <view class="card settings-card">
      <view class="settings-group-title">存储空间</view>
      <view class="settings-item" bindtap="clearCache">
        <text class="settings-label">清除缓存</text>
        <view class="settings-right">
          <text class="cache-size">{{cacheSize}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 账号 -->
    <view class="card settings-card">
      <view class="settings-group-title">账号</view>
      <view class="settings-item" bindtap="navigateTo" data-url="/pages/data-explanation/data-explanation">
        <text class="settings-label">数据说明</text>
        <text class="picker-arrow">›</text>
      </view>
      <view class="settings-divider"></view>
      <view class="settings-item" bindtap="navigateTo" data-url="/pages/about/about">
        <text class="settings-label">关于剧云榜</text>
        <text class="picker-arrow">›</text>
      </view>
      <view class="settings-divider"></view>
      <view class="settings-item" bindtap="checkUpdate">
        <text class="settings-label">检查更新</text>
        <text class="settings-value">v1.0.0</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="logout" wx:if="{{isLoggedIn}}">
      <text class="logout-text">退出登录</text>
    </view>

  </view>
</view>
