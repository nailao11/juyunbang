/* 数据中心样式 */

/* 日期选择器 */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 24rpx;
  padding: 20rpx 24rpx;
}

.date-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg);
}

.date-nav.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.date-arrow {
  font-size: 40rpx;
  color: var(--text);
  font-weight: 300;
}

.date-center {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.date-weekday {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 主榜单Tab */
.main-tabs {
  display: flex;
  position: relative;
  margin: 0 24rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 8rpx;
  box-shadow: var(--shadow);
}

.main-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  z-index: 1;
  transition: all 0.3s;
}

.main-tab-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  transition: color 0.3s;
}

.main-tab.active .main-tab-text {
  color: #fff;
  font-weight: 600;
}

.main-tab-indicator {
  position: absolute;
  top: 8rpx;
  width: 25%;
  height: calc(100% - 16rpx);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 14rpx;
  transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

/* 子Tab行 */
.sub-tabs-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.period-tabs {
  display: flex;
  background: var(--card);
  border-radius: 24rpx;
  padding: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.period-tab {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-radius: 20rpx;
  transition: all 0.3s;
}

.period-tab.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 600;
}

.type-filter-tabs {
  display: flex;
  gap: 16rpx;
}

.filter-tab {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
  position: relative;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* 排行项 */
.dc-rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.dc-rank-num-wrap {
  width: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dc-rank-medal {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.medal-num {
  font-size: 28rpx;
  font-weight: 800;
}

.dc-rank-num {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}

.dc-poster {
  width: 80rpx;
  height: 110rpx;
  border-radius: 12rpx;
  margin: 0 16rpx;
  flex-shrink: 0;
  background: var(--border);
}

.dc-info {
  overflow: hidden;
  min-width: 0;
}

.dc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dc-meta {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
  gap: 8rpx;
}

.dc-genre {
  font-size: 22rpx;
  color: var(--text-light);
}

.dc-data-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 12rpx;
}

.dc-data-value {
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  -webkit-background-clip: text;
  color: transparent;
}

.dc-trend {
  font-size: 22rpx;
}

.dc-rank-change {
  flex-shrink: 0;
  margin-left: 12rpx;
  text-align: center;
  min-width: 60rpx;
}

.rank-change-text {
  font-size: 24rpx;
  font-weight: 600;
}
