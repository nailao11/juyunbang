/* 追剧清单样式 */

/* Tab */
.tl-tabs {
  display: flex;
  background: var(--card);
  padding: 8rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tl-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tl-tab-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.3s;
}

.tl-tab.active .tl-tab-text {
  color: var(--primary);
  font-weight: 700;
}

.tl-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--accent));
  border-radius: 3rpx;
}

.tl-tab-count {
  font-size: 20rpx;
  color: #fff;
  background: var(--primary);
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 列表项 */
.tl-item {
  padding: 20rpx;
}

.tl-item-main {
  display: flex;
  align-items: flex-start;
}

.tl-poster {
  width: 100rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: var(--border);
}

.tl-info {
  overflow: hidden;
  min-width: 0;
}

.tl-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tl-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 8rpx;
}

.tl-status {
  font-size: 22rpx;
}

/* 进度条 */
.tl-progress {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background: var(--border);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 5rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  min-width: 100rpx;
}

/* 评分 */
.tl-rating {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 8rpx;
}

.rating-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.rating-stars {
  font-size: 24rpx;
}

.tl-time {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
  margin-top: 8rpx;
}

/* 操作区 */
.tl-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.tl-action-btn {
  padding: 8rpx 24rpx;
  border: 2rpx solid var(--primary);
  border-radius: 24rpx;
}

.tl-action-btn .action-btn-text {
  font-size: 24rpx;
  color: var(--primary);
}

.tl-action-btn.danger {
  border-color: var(--text-light);
}

.tl-action-btn.danger .action-btn-text {
  color: var(--text-light);
}
