<!--pages/tracking-report/tracking-report.wxml - 追剧报告-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">

  <!-- 报告头部 -->
  <view class="report-header">
    <view class="report-header-bg"></view>
    <view class="report-header-content">
      <text class="report-title">我的追剧报告</text>
      <text class="report-period">{{reportPeriod}}</text>
    </view>
  </view>

  <view class="container">

    <!-- 总览数据 -->
    <view class="card report-overview">
      <text class="overview-title">追剧总览</text>
      <view class="overview-grid">
        <view class="overview-item">
          <text class="ov-num">{{report.total_dramas || 0}}</text>
          <text class="ov-label">追剧总数</text>
        </view>
        <view class="overview-item">
          <text class="ov-num">{{report.total_episodes || 0}}</text>
          <text class="ov-label">观看集数</text>
        </view>
        <view class="overview-item">
          <text class="ov-num">{{report.total_hours || 0}}</text>
          <text class="ov-label">观看时长(h)</text>
        </view>
        <view class="overview-item">
          <text class="ov-num">{{report.total_notes || 0}}</text>
          <text class="ov-label">追剧笔记</text>
        </view>
      </view>
    </view>

    <!-- 追剧类型偏好 -->
    <view class="card report-section">
      <text class="section-card-title-text">类型偏好</text>
      <view class="genre-bars">
        <view class="genre-bar-item" wx:for="{{report.genre_stats}}" wx:key="genre">
          <text class="gb-label">{{item.genre}}</text>
          <view class="gb-bar">
            <view class="gb-bar-fill" style="width: {{item.percent || 0}}%;"></view>
          </view>
          <text class="gb-count">{{item.count}}部</text>
        </view>
      </view>
    </view>

    <!-- 追剧时间线 -->
    <view class="card report-section">
      <text class="section-card-title-text">追剧时间线</text>
      <view class="timeline">
        <view class="timeline-item" wx:for="{{report.timeline}}" wx:key="date">
          <view class="tl-date">
            <text class="tl-month">{{item.month}}</text>
            <text class="tl-day">{{item.day}}</text>
          </view>
          <view class="tl-line">
            <view class="tl-dot"></view>
          </view>
          <view class="tl-content">
            <text class="tl-title">{{item.title}}</text>
            <text class="tl-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 评分统计 -->
    <view class="card report-section">
      <text class="section-card-title-text">我的评分分布</text>
      <view class="rating-dist">
        <view class="rating-bar" wx:for="{{report.rating_stats}}" wx:key="score">
          <text class="rb-label">{{item.score}}星</text>
          <view class="rb-bar">
            <view class="rb-bar-fill" style="width: {{item.percent || 0}}%;"></view>
          </view>
          <text class="rb-count">{{item.count}}</text>
        </view>
      </view>
    </view>

    <!-- 分享按钮 -->
    <button class="btn-primary share-report-btn" open-type="share">
      分享我的追剧报告
    </button>

  </view>
</view>
