/* 追剧报告样式 */

.report-header {
  position: relative;
  padding: 60rpx 32rpx;
  overflow: hidden;
}

.report-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.report-header-content {
  position: relative;
  z-index: 2;
  text-align: center;
}

.report-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.report-period {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 12rpx;
}

/* 总览 */
.report-overview {
  margin-top: -30rpx;
  position: relative;
  z-index: 3;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 20rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.ov-num {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  color: transparent;
}

.ov-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 区块 */
.report-section {
  padding: 28rpx;
}

.section-card-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 20rpx;
}

/* 类型偏好 */
.genre-bars {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.genre-bar-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.gb-label {
  font-size: 26rpx;
  color: var(--text);
  width: 80rpx;
  flex-shrink: 0;
}

.gb-bar {
  flex: 1;
  height: 16rpx;
  background: var(--border);
  border-radius: 8rpx;
  overflow: hidden;
}

.gb-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #f093fb);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.gb-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 60rpx;
  flex-shrink: 0;
  text-align: right;
}

/* 时间线 */
.timeline {
  padding-left: 16rpx;
}

.timeline-item {
  display: flex;
  min-height: 100rpx;
}

.tl-date {
  width: 80rpx;
  flex-shrink: 0;
  text-align: center;
}

.tl-month {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
}

.tl-day {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
}

.tl-line {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
}

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  flex-shrink: 0;
  margin-top: 8rpx;
}

.tl-line::after {
  content: '';
  position: absolute;
  top: 28rpx;
  width: 2rpx;
  height: calc(100% - 28rpx);
  background: var(--border);
}

.timeline-item:last-child .tl-line::after {
  display: none;
}

.tl-content {
  flex: 1;
  padding-bottom: 24rpx;
}

.tl-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.tl-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* 评分分布 */
.rating-dist {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rating-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rb-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 60rpx;
  flex-shrink: 0;
}

.rb-bar {
  flex: 1;
  height: 14rpx;
  background: var(--border);
  border-radius: 7rpx;
  overflow: hidden;
}

.rb-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 7rpx;
}

.rb-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 40rpx;
  flex-shrink: 0;
  text-align: right;
}

/* 分享按钮 */
.share-report-btn {
  margin: 32rpx 0;
  border: none;
  line-height: normal;
}

.share-report-btn::after {
  border: none;
}
