/* 搜索页样式 */

/* 搜索头部 */
.search-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 24rpx;
}

.search-row {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  height: 88rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-input-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  height: 72rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.clear-icon {
  font-size: 36rpx;
  color: #adb5bd;
}

.search-cancel {
  margin-left: 20rpx;
  flex-shrink: 0;
}

.cancel-text {
  font-size: 28rpx;
  color: #fff;
}

/* 自动补全 */
.suggest-list {
  background: var(--card);
  margin: 0 24rpx;
  border-radius: 0 0 var(--radius) var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.suggest-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.suggest-item:last-child {
  border-bottom: none;
}

.suggest-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.suggest-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.suggest-type {
  font-size: 22rpx;
  color: var(--text-light);
  padding: 2rpx 12rpx;
  background: var(--bg);
  border-radius: 8rpx;
}

/* 搜索主页 */
.search-home {
  padding: 24rpx;
}

.search-section {
  margin-bottom: 32rpx;
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  padding: 12rpx 24rpx;
  background: var(--card);
  border-radius: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tag-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 热搜榜 */
.hot-list {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  font-size: 30rpx;
  font-weight: 800;
  width: 48rpx;
  text-align: center;
  color: var(--text-light);
  flex-shrink: 0;
}

.hot-rank.hot-top {
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  color: transparent;
  font-size: 34rpx;
}

.hot-info {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  gap: 8rpx;
}

.hot-keyword {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.hot-badge {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #f5365c, #f093fb);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.hot-count {
  font-size: 22rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

/* 搜索结果 */
.result-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.result-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
}

.result-poster {
  width: 100rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: var(--border);
}

.result-info {
  overflow: hidden;
  min-width: 0;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 8rpx;
}

.result-genre {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.result-sub {
  margin-top: 8rpx;
}

.result-cast {
  font-size: 24rpx;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.result-bottom {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 20rpx;
}

.result-score {
  font-size: 24rpx;
  color: #FFD700;
  font-weight: 600;
}

.result-heat {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}
