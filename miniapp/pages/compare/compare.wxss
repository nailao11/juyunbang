/* 数据对比样式 */

.compare-select-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.compare-slot {
  flex: 1;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 20rpx;
}

.slot-poster {
  width: 120rpx;
  height: 168rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: var(--border);
}

.slot-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.slot-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 28rpx;
  color: #fff;
}

.slot-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.slot-add-icon {
  font-size: 56rpx;
  color: var(--text-light);
  line-height: 1;
}

.slot-add-text {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 12rpx;
}

.compare-vs {
  flex-shrink: 0;
}

.vs-text {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  color: transparent;
}

/* 对比数据行 */
.compare-data-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.compare-row {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 8rpx;
}

.compare-value-a,
.compare-value-b {
  flex: 1;
  text-align: center;
}

.compare-value-a { text-align: left; padding-left: 16rpx; }
.compare-value-b { text-align: right; padding-right: 16rpx; }

.cv-num {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.compare-value-a.win .cv-num,
.compare-value-b.win .cv-num {
  color: var(--primary);
}

.compare-label-center {
  flex-shrink: 0;
  width: 160rpx;
  text-align: center;
}

.cl-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 综合对比 */
.compare-summary {
  margin-top: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 16rpx;
}

.summary-bar {
  display: flex;
  height: 40rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.summary-bar-a {
  background: linear-gradient(90deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.5s ease;
}

.summary-bar-b {
  background: linear-gradient(90deg, #f093fb, #f5576c);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.5s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 8rpx;
}

.summary-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  display: block;
}
