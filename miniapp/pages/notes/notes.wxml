<!--pages/notes/notes.wxml - 追剧笔记-->
<view class="page-bg {{darkMode ? 'dark-mode' : ''}}">

  <!-- 写笔记模式 -->
  <view class="note-editor container" wx:if="{{isEditing}}">
    <view class="card editor-card">
      <!-- 关联剧集 -->
      <view class="editor-drama" wx:if="{{currentDrama}}" bindtap="selectDrama">
        <image class="ed-poster" src="{{currentDrama.poster_url || '/images/default/poster.png'}}"
               mode="aspectFill"></image>
        <text class="ed-title">{{currentDrama.title}}</text>
        <text class="ed-change">更换</text>
      </view>
      <view class="editor-drama empty" wx:else bindtap="selectDrama">
        <text class="ed-add">+ 关联剧集</text>
      </view>

      <!-- 集数 -->
      <view class="editor-episode" wx:if="{{currentDrama}}">
        <text class="ep-label">看到第</text>
        <input class="ep-input" type="number" value="{{noteEpisode}}"
               bindinput="onEpisodeInput" placeholder="?" />
        <text class="ep-label">集</text>
      </view>

      <!-- 内容 -->
      <textarea class="editor-textarea" placeholder="写下你的追剧感想..."
                value="{{noteContent}}" bindinput="onNoteInput"
                maxlength="2000" auto-height />

      <!-- 图片 -->
      <view class="editor-images">
        <view class="ei-item" wx:for="{{noteImages}}" wx:key="*this">
          <image class="ei-img" src="{{item}}" mode="aspectFill"></image>
          <view class="ei-del" catchtap="removeNoteImage" data-index="{{index}}">
            <text class="del-x">×</text>
          </view>
        </view>
        <view class="ei-add" wx:if="{{noteImages.length < 9}}" bindtap="addNoteImage">
          <text class="add-plus">+</text>
        </view>
      </view>

      <!-- 操作栏 -->
      <view class="editor-actions">
        <view class="ea-left">
          <text class="ea-count">{{noteContent.length}}/2000</text>
        </view>
        <view class="ea-right">
          <view class="ea-cancel" bindtap="cancelEdit">
            <text class="ea-cancel-text">取消</text>
          </view>
          <view class="btn-primary ea-save" bindtap="saveNote">
            <text>保存</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 笔记列表模式 -->
  <block wx:else>
    <!-- 添加笔记按钮 -->
    <view class="note-add-bar" bindtap="startEdit">
      <view class="note-add-btn">
        <text class="note-add-icon">✏️</text>
        <text class="note-add-text">写追剧笔记</text>
      </view>
    </view>

    <!-- 笔记列表 -->
    <view class="notes-list container" wx:if="{{notesList.length > 0}}">
      <view class="note-card card" wx:for="{{notesList}}" wx:key="id">
        <!-- 关联剧集 -->
        <view class="nc-drama" wx:if="{{item.drama_title}}"
              bindtap="goDetail" data-id="{{item.drama_id}}">
          <image class="nc-poster" src="{{item.poster_url || '/images/default/poster.png'}}"
                 mode="aspectFill"></image>
          <view class="nc-drama-info">
            <text class="nc-drama-title">{{item.drama_title}}</text>
            <text class="nc-episode" wx:if="{{item.episode}}">第{{item.episode}}集</text>
          </view>
        </view>

        <!-- 笔记内容 -->
        <text class="nc-content">{{item.content}}</text>

        <!-- 图片 -->
        <view class="nc-images" wx:if="{{item.images && item.images.length > 0}}">
          <image class="nc-img" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
                 src="{{img}}" mode="aspectFill"
                 bindtap="previewImage" data-urls="{{item.images}}" data-current="{{img}}">
          </image>
        </view>

        <!-- 底部 -->
        <view class="nc-footer">
          <text class="nc-time">{{item.time_display}}</text>
          <view class="nc-actions-row">
            <view class="nc-action" catchtap="editNote" data-note="{{item}}">
              <text class="nca-text">编辑</text>
            </view>
            <view class="nc-action" catchtap="deleteNote" data-id="{{item.id}}">
              <text class="nca-text danger">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-dots" wx:if="{{loading}}">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && notesList.length === 0}}">
      <image src="/images/default/empty.png" class="icon" mode="aspectFit"></image>
      <text class="text">还没有追剧笔记</text>
      <text class="text" style="font-size:24rpx;margin-top:12rpx;">记录每一次追剧感动</text>
    </view>
  </block>

</view>
