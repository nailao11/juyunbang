/* 追剧笔记样式 */

/* 添加按钮 */
.note-add-bar {
  padding: 24rpx;
}

.note-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  border: 2rpx dashed var(--primary);
}

.note-add-icon {
  font-size: 32rpx;
}

.note-add-text {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 编辑器 */
.editor-card {
  padding: 24rpx;
}

.editor-drama {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
}

.editor-drama.empty {
  justify-content: center;
  padding: 24rpx;
  border: 2rpx dashed var(--border);
  background: transparent;
}

.ed-poster {
  width: 56rpx;
  height: 78rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--border);
}

.ed-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ed-change {
  font-size: 24rpx;
  color: var(--primary);
  flex-shrink: 0;
}

.ed-add {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 集数 */
.editor-episode {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 8rpx;
}

.ep-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.ep-input {
  width: 80rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
  border-bottom: 2rpx solid var(--primary);
  padding: 4rpx 0;
}

/* 文本域 */
.editor-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 30rpx;
  color: var(--text);
  line-height: 1.8;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

/* 图片 */
.editor-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.ei-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.ei-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  background: var(--border);
}

.ei-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--danger);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.del-x {
  font-size: 22rpx;
  color: #fff;
}

.ei-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-plus {
  font-size: 48rpx;
  color: var(--text-light);
}

/* 编辑操作栏 */
.editor-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.ea-count {
  font-size: 22rpx;
  color: var(--text-light);
}

.ea-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ea-cancel {
  padding: 12rpx 24rpx;
}

.ea-cancel-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.ea-save {
  padding: 12rpx 36rpx;
  font-size: 26rpx;
}

/* 笔记卡片 */
.note-card {
  padding: 24rpx;
}

.nc-drama {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
}

.nc-poster {
  width: 48rpx;
  height: 66rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  background: var(--border);
}

.nc-drama-info {
  flex: 1;
  overflow: hidden;
}

.nc-drama-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nc-episode {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.nc-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.8;
  display: block;
}

/* 笔记图片 */
.nc-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.nc-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background: var(--border);
}

/* 底部 */
.nc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

.nc-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.nc-actions-row {
  display: flex;
  gap: 20rpx;
}

.nc-action {
  padding: 4rpx 0;
}

.nca-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.nca-text.danger {
  color: var(--danger);
}
