# 服务器配置
FLASK_ENV=production
SECRET_KEY=部署时自动生成

# MySQL数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rejubang
DB_USER=rejubang
DB_PASSWORD=替换为你的数据库密码

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 微信小程序配置
WX_APPID=替换为你的小程序AppID
WX_SECRET=替换为你的小程序AppSecret

# 七牛云配置
QINIU_ACCESS_KEY=替换为你的七牛云AccessKey
QINIU_SECRET_KEY=替换为你的七牛云SecretKey
QINIU_BUCKET=rejubang
QINIU_DOMAIN=替换为你的七牛云域名

# JWT配置
JWT_SECRET_KEY=部署时自动生成
JWT_ACCESS_TOKEN_EXPIRES=86400
